<!-- components/navigation-bar/navigation-bar.wxml -->
<view class="nav-bar {{fixed ? 'fixed' : ''}}">
  <view class="nav-bar-content" style="padding-top: {{statusBarHeight}}px;">
    <view class="left">
      <slot name="left"></slot>
    </view>
    <view class="center">
      <slot name="center"></slot>
    </view>
    <view class="right">
      <view class="user-btn" bindtap="toggleDropdown">
        <image class="user-icon" src="/assets/icons/user.png" mode="aspectFit"></image>
      </view>
    </view>
  </view>
  
  <!-- 下拉菜单遮罩 -->
  <view 
    class="dropdown-mask {{showDropdown ? 'show' : ''}}" 
    bindtap="closeDropdown" 
    capture-bind:touchmove="preventTouchMove"
  ></view>
  
  <!-- 下拉菜单 -->
  <view class="dropdown-menu {{showDropdown ? 'show' : ''}}">
    <!-- 我的 - 始终显示 -->
    <view class="menu-item" bindtap="navigateToProfile">
      <image class="menu-icon" src="/assets/icons/profile.png" mode="aspectFit"></image>
      <view class="menu-text">我的</view>
    </view>
    
    <!-- 历史记录 - 仅登录状态显示 -->
    <view class="menu-item" 
          bindtap="navigateToHistory" 
          wx:if="{{isLoggedIn}}">
      <image class="menu-icon" src="/assets/icons/history.png" mode="aspectFit"></image>
      <view class="menu-text">历史记录</view>
    </view>
    
    <!-- 登录/退出按钮 -->
    <view class="menu-item {{isLoggedIn ? 'logout' : 'login'}}" 
          bindtap="handleLoginOrLogout">
      <image 
        class="menu-icon" 
        src="/assets/icons/{{isLoggedIn ? 'logout' : 'login'}}.png" 
        mode="aspectFit"
      ></image>
      <view class="menu-text">{{isLoggedIn ? '退出登录' : '去登录'}}</view>
    </view>
  </view>
</view>