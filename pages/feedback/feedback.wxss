.feedback-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 48rpx;
}

/* 顶部导航 */
.search-bar {
  padding: 180rpx 32rpx 20rpx;
  display: flex;
  align-items: center;
  background: #fff;
  gap: 20rpx;
}

.back-btn {
  padding: 8rpx;
}

.back-arrow {
  font-size: 40rpx;
  color: #333;
  font-weight: 600;
  transform: scale(0.8, 1.2);
}

.page-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 通用卡片样式 */
.section {
  margin: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 24rpx;
}

/* 反馈类型样式 */
.type-group {
  display: flex;
  gap: 24rpx;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.type-item.active {
  background: var(--color-primary);
  color: #fff;
}

/* 反馈内容输入框 */
.content-box {
  position: relative;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
}

.content-input {
  width: 100%;
  height: 300rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.word-count {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  font-size: 24rpx;
  color: #999;
}

/* 图片上传样式 */
.image-uploader {
  margin-top: 20rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.upload-btn {
  width: 180rpx;
  height: 180rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
}

.upload-icon {
  font-size: 60rpx;
  font-weight: 300;
}

/* 联系方式输入框 */
.contact-input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
}

/* 提交按钮 */
.submit-btn {
  width: calc(100% - 64rpx);
  margin: 48rpx 32rpx;
  background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
  color: #fff;
  border-radius: 999rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  border: none;
  transition: all 0.3s ease;
}

.submit-btn.submitting {
  opacity: 0.7;
}

.submit-btn::after {
  border: none;
}