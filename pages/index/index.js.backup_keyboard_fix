  // UTF-8解码函数
  decodeUTF8: function(arrayBuffer) {
    const uint8Array = new Uint8Array(arrayBuffer);
    let str = '';
    let i = 0;
    
    while (i < uint8Array.length) {
      let codePoint;
      
      // 单字节字符 (0x00-0x7F)
      if ((uint8Array[i] & 0x80) === 0) {
        codePoint = uint8Array[i++];
      } 
      // 双字节字符 (0xC0-0xDF 后跟一个字节)
      else if ((uint8Array[i] & 0xE0) === 0xC0) {
        codePoint = ((uint8Array[i] & 0x1F) << 6) |
                   (uint8Array[i+1] & 0x3F);
        i += 2;
      } 
      // 三字节字符 (0xE0-0xEF 后跟两个字节)
      else if ((uint8Array[i] & 0xF0) === 0xE0) {
        codePoint = ((uint8Array[i] & 0x0F) << 12) |
                   ((uint8Array[i+1] & 0x3F) << 6) |
                   (uint8Array[i+2] & 0x3F);
        i += 3;
      } 
      // 四字节字符 (0xF0-0xF7 后跟三个字节)
      else if ((uint8Array[i] & 0xF8) === 0xF0) {
        codePoint = ((uint8Array[i] & 0x07) << 18) |
                   ((uint8Array[i+1] & 0x3F) << 12) |
                   ((uint8Array[i+2] & 0x3F) << 6) |
                   (uint8Array[i+3] & 0x3F);
        i += 4;
      } else {
        // 跳过无效字节
        i++;
        continue;
      }
      
      // 将代码点转换为字符并追加到结果字符串
      if (codePoint <= 0xFFFF) {
        str += String.fromCharCode(codePoint);
      } else {
        // 处理需要代理对的字符
        codePoint -= 0x10000;
        str += String.fromCharCode(
          (codePoint >> 10) + 0xD800,  // 高位代理
          (codePoint & 0x3FF) + 0xDC00 // 低位代理
        );
      }
    }
    
    return str;
  },

