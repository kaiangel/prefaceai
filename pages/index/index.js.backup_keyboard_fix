  // 修改formatResult方法，支持Markdown语法
  formatResult: function(rawResult) {
    if (!rawResult || rawResult.trim() === '') {
      return { sections: [] };
    }

    LogManager.logOnce('开始格式化Markdown内容');

    const lines = rawResult.split('\n').filter(line => line.trim());
    const formattedResult = { sections: [] };
    let currentSection = { title: '', content: [], level: 0 };

    lines.forEach((line) => {
      const trimmedLine = line.trim();
      
      // 处理标题 (# ## ###)
      const headerMatch = trimmedLine.match(/^(#{1,6})\s+(.+)$/);
      if (headerMatch) {
        // 如果当前section有内容，先保存
        if (currentSection.content.length > 0 || currentSection.title) {
          formattedResult.sections.push({...currentSection});
        }
        
        // 开始新的section
        currentSection = {
          title: headerMatch[2],
          content: [],
          level: headerMatch[1].length, // 标题层级
          type: 'header'
        };
        return;
      }
      
      // 处理分割线
      if (trimmedLine.match(/^[-*_]{3,}$/)) {
        currentSection.content.push({
          type: 'divider',
          text: ''
        });
        return;
      }
      
      // 处理引用块
      if (trimmedLine.startsWith('>')) {
        const quoteText = trimmedLine.substring(1).trim();
        currentSection.content.push({
          type: 'quote',
          text: quoteText
        });
        return;
      }
      
      // 处理普通文本（含加粗、斜体等）
      if (trimmedLine) {
        currentSection.content.push({
          type: 'text',
          text: trimmedLine,
          formatted: this.parseInlineMarkdown(trimmedLine)
        });
      }
    });
    
    // 保存最后一个section
    if (currentSection.content.length > 0 || currentSection.title) {
      formattedResult.sections.push(currentSection);
    }

    LogManager.logOnce('Markdown格式化完成', `共有 ${formattedResult.sections.length} 个部分`);
    return formattedResult;
  },

  // 新增：解析行内Markdown语法
  parseInlineMarkdown: function(text) {
    const segments = [];
    let current = '';
    let i = 0;
    
    while (i < text.length) {
      // 处理加粗 **text**
      if (text.substring(i, i + 2) === '**') {
        if (current) {
          segments.push({ type: 'normal', text: current });
          current = '';
        }
        
        let j = i + 2;
        let boldText = '';
        
        // 查找结束的 **
        while (j < text.length - 1) {
          if (text.substring(j, j + 2) === '**') {
            segments.push({ type: 'bold', text: boldText });
            i = j + 2;
            break;
          }
          boldText += text[j];
          j++;
        }
        
        // 如果没找到结束符，按普通文本处理
        if (j >= text.length - 1) {
          current += text.substring(i, i + 2);
          i += 2;
        }
        continue;
      }
      
      // 处理斜体 *text* (但不是列表项)
      if (text[i] === '*' && text[i + 1] !== '*' && !text.trim().startsWith('*')) {
        if (current) {
          segments.push({ type: 'normal', text: current });
          current = '';
        }
        
        let j = i + 1;
        let italicText = '';
        
        // 查找结束的 *
        while (j < text.length) {
          if (text[j] === '*' && text[j + 1] !== '*') {
            segments.push({ type: 'italic', text: italicText });
            i = j + 1;
            break;
          }
          italicText += text[j];
          j++;
        }
        
        // 如果没找到结束符，按普通文本处理
        if (j >= text.length) {
          current += text[i];
          i++;
        }
        continue;
      }
      
      current += text[i];
      i++;
    }
    
    if (current) {
      // 检查是否包含特殊标记（如单独的星号）
      const hasSpecialMark = current.includes('*') && !current.includes('**');
      segments.push({ 
        type: hasSpecialMark ? 'special' : 'normal', 
        text: current 
      });
    }
    
    return segments;
  },

