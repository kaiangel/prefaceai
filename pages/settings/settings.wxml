<view class="settings-container">
  <!-- 顶部导航 -->
  <view class="search-bar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-arrow">←</text>
    </view>
    <view class="page-title">通用设置</view>
  </view>

  <!-- 设置列表 -->
  <view class="settings-list">
    <!-- 通知设置 -->
    <view class="settings-item">
      <view class="item-left">
        <image class="item-icon" src="/assets/icons/notification.png"></image>
        <text class="item-label">微信内通知</text>
      </view>
      <switch 
        class="setting-switch"
        checked="{{notificationEnabled}}"
        bindchange="toggleNotification"
        color="var(--color-primary)"
      />
    </view>

    <!-- 清除缓存 -->
    <view class="settings-item" bindtap="clearCache">
      <view class="item-left">
        <image class="item-icon" src="/assets/icons/clear.png"></image>
        <text class="item-label">清除缓存</text>
      </view>
      <view class="item-right">
        <text class="cache-size">{{cacheSize}}</text>
        <text class="arrow">→</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="settings-item settings-item-signout" bindtap="handleSignOut" wx:if="{{isLoggedIn}}">
      <view class="item-left">
        <image class="item-icon" src="/assets/icons/logout.png"></image>
        <text class="item-label">退出登录</text>
      </view>
      <view class="item-right">
        <text class="arrow">→</text>
      </view>
    </view>
  </view>
</view>