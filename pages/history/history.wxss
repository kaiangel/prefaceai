/* 新增：历史记录页面容器样式 */
.history-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx; /* 为TabBar预留空间 */
  padding-top:0vh;
  width: 100%;
  overflow-x: hidden;
}

/* 新增：页面顶部标题区域 */
.page-header {
  background: #fff;
  padding: 106rpx 32rpx 30rpx;
  text-align: center;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* 新增：页面标题文字样式 */
.page-title {
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 刷新按钮样式 */
.refresh-btn {
  position: absolute;
  left: 32rpx;
  /* Ultra Think分析：header使用flex布局，文字实际位置需要考虑flex居中 */
  /* header总高度≈186rpx，文字在flex容器中居中，实际位置约在整个header的中心偏下 */
  top: 140rpx; /* 调整到与文字更精确对齐的位置 */
  transform: translateY(-50%);
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f9fa;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.refresh-btn:active {
  transform: translateY(-50%) scale(0.95);
  background: #e9ecef;
}

.refresh-icon {
  width: 28rpx; /* 相应缩小图标 */
  height: 28rpx;
}

/* 保留搜索框相关样式,但隐藏显示 */
.search-box {
  flex: 1;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* 操作按钮组样式 */
.action-buttons {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
  background: transparent;
  border: none;
  min-height: auto;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
  transition: opacity 0.2s ease;
  display: block; /* 确保图标显示 */
}

.action-btn:active .action-icon {
  opacity: 1;
}

/* 分享按钮特殊样式 - 严格控制button尺寸 */
.share-item-btn {
  background: transparent !important;
  border: none !important;
  /* 🔑 关键修复：严格限制button的尺寸和点击区域 */
  width: 48rpx !important;
  height: 48rpx !important;
  padding: 8rpx !important;
  margin: 0 !important;
  box-sizing: border-box !important;
  overflow: hidden !important;
  /* 移除默认样式并严格限制尺寸 */
  border-radius: 0 !important;
  font-size: 0 !important;
  line-height: 1 !important;
  max-width: 48rpx !important;
  max-height: 48rpx !important;
  min-width: 48rpx !important;
  min-height: 48rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  /* 防止button扩展点击区域 */
  position: relative;
  z-index: 1;
}

.share-item-btn::after {
  border: none !important;
  background: none !important;
}

.share-item-btn .action-icon {
  opacity: 0.5;
}

.share-item-btn:active .action-icon {
  opacity: 0.8;
}

/* 收藏按钮样式 */
.favorite-btn {
  background: transparent !important;
  border: none !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 8rpx !important;
  margin: 0 !important;
  min-height: auto !important;
  line-height: 1 !important;
  /* 🔑 确保与分享按钮尺寸完全一致 */
  width: 48rpx !important;
  height: 48rpx !important;
  box-sizing: border-box !important;
  max-width: 48rpx !important;
  max-height: 48rpx !important;
  min-width: 48rpx !important;
  min-height: 48rpx !important;
  /* 确保收藏按钮在层级上不被遮挡 */
  position: relative;
  z-index: 2;
}

.favorite-btn::after {
  border: none !important;
}

.favorite-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
  transition: opacity 0.2s ease;
}

.favorite-icon.active {
  opacity: 1;
  filter: invert(70%) sepia(80%) saturate(1000%) hue-rotate(360deg) brightness(105%) contrast(105%);
}

/* 历史记录列表样式 */
.history-list {
  padding: 32rpx;
  /* 调整高度计算，考虑新增的标题区域 */
  height: calc(100vh - 200rpx);
  box-sizing: border-box;
}

.history-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

/* 修改原有的 item-header */
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

/* 修改这个样式，从垂直布局改为水平布局 */
.header-left {
  display: flex;
  flex-direction: row;  /* 改为水平布局 */
  align-items: center;  /* 垂直居中对齐 */
  gap: 12rpx;          /* 日期和标签之间的间距 */
}

/* 模型标签样式 */
.model-label {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  line-height: 1.2;
  max-width: fit-content;
}

.model-text {
  font-weight: 500;
  white-space: nowrap;
}

/* 不同模型类型的颜色区分 - 新版class方式 */
.model-label.text-type {
  background: rgba(67, 182, 146, 0.15);
  color: #43B692;
}

.model-label.image-type {
  background: rgba(63, 136, 197, 0.15);
  color: #3F88C5;
}

.model-label.video-type {
  background: rgba(155, 89, 182, 0.15);
  color: #9B59B6;
}

/* 早期记录的data-type方式（兼容性支持） */
.model-label[data-type="text"] {
  background: rgba(67, 182, 146, 0.15);
  color: #43B692;
}

.model-label[data-type="image"] {
  background: rgba(63, 136, 197, 0.15);
  color: #3F88C5;
}

.model-label[data-type="video"] {
  background: rgba(155, 89, 182, 0.15);
  color: #9B59B6;
}

/* 确保日期文字不会被挤压 */
.item-date {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;  /* 防止日期文字被压缩 */
}

.delete-btn {
  padding: 8rpx;
}

.delete-btn image {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
}

.content-preview {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 列表项图片预览容器 */
.preview-with-image {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

/* 列表项图片缩略图 */
.preview-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.preview-with-image .content-preview {
  flex: 1;
  -webkit-line-clamp: 4;
}


/* 弹窗样式(完全复用favorites的弹窗样式) */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.detail-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
}

.modal-content {
  position: relative;
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 1001;
  transform: translateY(20rpx);
  transition: all 0.3s ease;
  margin: 60rpx auto;
}

.detail-modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1px solid rgba(0,0,0,0.05);
}

/* 新增：替换关闭按钮位置的分享按钮 - 与收藏页面保持一致 */
.share-btn-replace-close {
  background: rgba(67, 182, 146, 0.1) !important;
  border: none !important;
  border-radius: 50% !important;
  width: 80rpx !important;
  height: 80rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  min-height: auto !important;
  line-height: 1 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.share-btn-replace-close:active {
  background: rgba(67, 182, 146, 0.2) !important;
  transform: scale(0.95);
}

.share-btn-replace-close::after {
  border: none !important;
}

.share-btn-replace-close image {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.8;
}

.modal-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.close-btn {
  font-size: 40rpx;
  color: #999;
  padding: 8rpx;
}

.modal-body {
  max-height: 70vh;
  padding: 32rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.prompt-section {
  margin-bottom: 32rpx;
}

.prompt-section:last-child {
  margin-bottom: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.copy-btn {
  padding: 8rpx;
}

.copy-btn image {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
}

.prompt-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  white-space: pre-wrap;
}

/* 图片输入容器 */
.input-with-image {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 参考图片样式 */
.reference-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

/* 图片描述文字 */
.image-description {
  font-size: 24rpx;
  color: #666;
  font-style: italic;
  padding: 8rpx 12rpx;
  background: rgba(67, 182, 146, 0.1);
  border-radius: 8rpx;
  border-left: 3rpx solid #43B692;
}


/* 富文本渲染样式 */
.formatted-content {
  padding: 0;
  background: transparent;
  margin-top: 16rpx;
}

.formatted-content .section {
  margin-bottom: 32rpx;
  padding: 0;
}

.formatted-content .section:last-child {
  margin-bottom: 0;
}

/* 标题层级样式 */
.formatted-content .section-title.level-1 {
  font-size: 32rpx !important;
  color: #43B692 !important;
  font-weight: 600 !important;
  margin: 24rpx 0 16rpx 0 !important;
  padding: 0 !important;
  border-bottom: 2rpx solid #43B692;
  text-align: left !important;
}

.formatted-content .section-title.level-2 {
  font-size: 30rpx !important;
  color: #3F88C5 !important;
  font-weight: 500 !important;
  margin: 20rpx 0 12rpx 0 !important;
  padding: 0 !important;
  border-bottom: 1rpx solid #3F88C5;
  text-align: left !important;
}

.formatted-content .section-title.level-3 {
  font-size: 28rpx !important;
  color: #2c3e50 !important;
  font-weight: 500 !important;
  margin: 16rpx 0 8rpx 0 !important;
  padding: 0 !important;
  text-align: left !important;
}

.formatted-content .section-content {
  padding: 8rpx 0;
  line-height: 1.8;
}

.formatted-content .content-line {
  margin: 8rpx 0;
  line-height: 1.8;
}

.formatted-content .content-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.8;
  word-break: break-word;
  white-space: pre-wrap;
}

/* 行内格式样式 */
.formatted-content .markdown-bold {
  font-weight: 600;
  color: #2c3e50;
}

.formatted-content .markdown-italic {
  font-style: italic;
  color: #34495e;
}

.formatted-content .special-mark {
  color: #43B692;
  font-weight: 500;
}

/* 引用块样式 */
.formatted-content .markdown-quote {
  display: flex;
  align-items: flex-start;
  margin: 12rpx 0;
  padding: 12rpx 0 12rpx 24rpx;
  background: rgba(67, 182, 146, 0.05);
  border-radius: 6rpx;
  position: relative;
}

.formatted-content .quote-line {
  position: absolute;
  left: 12rpx;
  top: 0;
  bottom: 0;
  width: 3rpx;
  background: #43B692;
  border-radius: 2rpx;
}

.formatted-content .quote-text {
  font-size: 24rpx;
  color: #5d6d7e;
  line-height: 1.6;
  font-style: italic;
}

/* 分割线样式 */
.formatted-content .markdown-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #bdc3c7, transparent);
  margin: 24rpx 0;
  border-radius: 1rpx;
}

/* 按钮组样式 */
.header-buttons {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 快速复制按钮特殊样式 */
.quick-copy-btn {
  background: rgba(67, 182, 146, 0.1);
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.quick-copy-btn:active {
  background: rgba(67, 182, 146, 0.2);
  transform: scale(0.95);
}

/* 闪电图标的颜色处理 */
.lightning-icon {
  opacity: 0.8;
  filter: invert(67%) sepia(13%) saturate(1200%) hue-rotate(118deg) brightness(89%) contrast(84%);
}

/* 确保copy-icon基础样式正确 */
.copy-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 标题和闪电按钮的组合容器 */
.title-with-lightning {
  display: flex;
  align-items: center;
  gap: 12rpx; /* 标题和闪电按钮之间的间距 */
}

/* 行内闪电按钮样式 - 更小更精致 */
.inline-lightning {
  background: rgba(67, 182, 146, 0.15);
  border-radius: 6rpx;
  padding: 8rpx; /* 比普通按钮更小的内边距 */
  transition: all 0.2s ease;
}

.inline-lightning:active {
  background: rgba(67, 182, 146, 0.25);
  transform: scale(0.95);
}

/* 行内闪电按钮中的图标 - 稍微小一点 */
.inline-lightning .copy-icon {
  width: 28rpx; /* 比普通复制按钮稍小 */
  height: 28rpx;
}